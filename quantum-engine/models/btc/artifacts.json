{
  "config": {
    "data": "data/btcusd_raw.csv",
    "outdir": "models/btc",
    "symbol": "BTCUSD",
    "qubits": 10,
    "layers": 3,
    "batch_size": 64,
    "lr": 0.003,
    "weight_decay": 0.0001,
    "epochs": 100,
    "val_ratio": 0.2,
    "timestamp_format": "%Y.%m.%d %H:%M",
    "max_train_rows": 50000,
    "max_seconds": 21600,
    "patience": 15,
    "min_delta": 0.0001,
    "seed": 42
  },
  "feature_cols": [
    "open",
    "high",
    "low",
    "close",
    "tick_volume",
    "ema_fast",
    "ema_slow",
    "ema_spread",
    "rsi",
    "atr",
    "adx",
    "wick_upper",
    "wick_lower",
    "wick_ratio",
    "candle_size",
    "volume_density",
    "volume_shock",
    "dom_pressure_proxy",
    "spread",
    "tick_rate",
    "bid_ask_imbalance"
  ],
  "backend": "lightning.qubit",
  "timestamp_format": "%Y.%m.%d %H:%M",
  "scheme": "C"
}