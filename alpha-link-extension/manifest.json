{
  "manifest_version": 3,
  "name": "AlphaLink",
  "version": "1.0",
  "description": "Sync TradingView trades to AlphaOS",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.tradingview.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tradingview.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
