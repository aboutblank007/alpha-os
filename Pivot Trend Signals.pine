//@version=6
indicator("Pivot Trend Signals (TP/SL) - Optimized V3", overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)
// ========== 1. 核心设置 (Core Settings) ==========
grp_core = "核心参数"
prd = input.int(2, title="枢轴点周期", minval = 1, maxval = 50, group = grp_core)
Pd = input.int(14, title = "ATR 周期", minval = 1, group = grp_core)
length1 = input.int(6, title="EMA短周期", group = grp_core)
length2 = 24 // 固定长周期，简化输入
// ========== 2. 过滤设置 (Filter Settings) ==========
grp_filter = "过滤模式"
filter_mode = input.string("基础过滤", "过滤强度", options = ["无过滤", "基础过滤", "严格过滤"], group = grp_filter, tooltip="无过滤:仅距离/斜率 | 基础过滤:+趋势 | 严格过滤:+波动+震荡")
min_distance = input.float(0.4, title="最小距离(ATR倍数)", minval=0.0, step=0.1, group = grp_filter)
// 优化: 趋势缓冲区 (Hysteresis)
trend_buffer_mult = input.float(0.1, title="趋势缓冲区(ATR倍数)", minval=0.0, step=0.1, group = grp_filter, tooltip="价格必须超过中心线一定距离才视为有效突破，防止在中心线附近反复震荡")
// 优化: 斜率过滤增强
use_slope_filter = input.bool(true, title="启用斜率加速", group = grp_filter)
slope_threshold = input.float(0.5, title="最小斜率阈值", minval=0.1, step=0.1, group = grp_filter)
strict_slope = input.bool(true, title="严格斜率(连续2根)", group = grp_filter, tooltip="要求连续两根K线斜率都达标，防止单根K线骗线")
// 优化: EMA 分离度
min_ema_spread_mult = input.float(0.1, title="最小EMA分离(ATR倍数)", minval=0.0, step=0.1, group = grp_filter, tooltip="EMA双线必须有一定开口，避免粘合时频繁交易")
min_bars_between_signals = input.int(3, title="信号最小间隔", minval=1, maxval=20, group = grp_filter)
// HTF Filter
use_htf_filter = input.bool(true, title="启用多周期趋势过滤", group = grp_filter) // 默认开启
htf_period = input.timeframe("60", title="高位周期", group = grp_filter)
// ========== 3. 延续/Reclaim (Continuation) ==========
grp_reclaim = "延续/Reclaim"
use_reclaim = input.bool(true, title="启用 Reclaim (回调) 信号", group = grp_reclaim)
reclaim_strict_mode = input.bool(true, title="Reclaim 严格过滤 (ADX>20)", group = grp_reclaim)
// ========== 4. 风险控制 (Risk Management) ==========
grp_risk = "风险控制"
tp_atr_mult = input.float(1.5, title="TP ATR倍数", minval=0.1, step=0.1, group=grp_risk)
sl_atr_mult = input.float(1.0, title="SL ATR倍数", minval=0.1, step=0.1, group=grp_risk)
tp_sl_base = input.string("信号收盘价", title="TP/SL基准", options=["信号收盘价","中心线"], group=grp_risk)
// ========== 5. 外观设置 (Appearance) ==========
grp_disp = "显示选项"
showcl = input.bool(false, title="显示中心线", group = grp_disp)
show_trend_fill = input.bool(true, title="显示趋势填充", group = grp_disp)
show_history_labels = input.bool(true, title="显示历史标签", group = grp_disp, tooltip="关闭后只显示图表上最后一个信号标签")
col1 = input.color(#26ba9f, title="买入颜色", inline = "col", group = grp_disp)
col2 = input.color(#ba3026, title="卖出颜色", inline = "col", group = grp_disp)
label_offset_mult = input.float(1.0, title="标签偏移(ATR倍数)", minval=0.0, step=0.1, group = grp_disp)
label_size_mode = input.string("正常", title="标签大小", options=["小","正常","大"], group=grp_disp)
show_trend_table = input.bool(true, title="显示趋势表", group = grp_disp)
// ==========================================
// 计算逻辑 (Calculation Logic)
// ==========================================
// 1. Pivot Point & Center Line
float ph = ta.pivothigh(prd, prd)
float pl = ta.pivotlow(prd, prd)
var float center = na
float lastpp = not na(ph) ? ph : not na(pl) ? pl : na
if not na(lastpp)
    if na(center)
        center := lastpp
    else
        center := (center * 2 + lastpp) / 3
// 2. EMAs & ATR
float ema1 = ta.ema(close, length1)
float ema2 = ta.ema(close, length2)
float atr_val = ta.atr(Pd)
[diplus, diminus, adx] = ta.dmi(14, 14)
// 3. 趋势状态
bool cross_up = ta.crossover(ema1, ema2)
bool cross_dn = ta.crossunder(ema1, ema2)
bool trend_up = ema1 > ema2
float difff = ema2 - ema1
// 4. 过滤条件计算
// 4.1 距离过滤
float atr_distance = (not na(center) and not na(atr_val) and atr_val != 0) ? math.abs(close - center) / atr_val : na
// [优化] 斜率过滤 (Slope Persistence)
float ema1_slope = math.abs(ema1 - ema1[1]) / syminfo.mintick
bool slope_val_ok = ema1_slope > slope_threshold
bool slope_persistent = strict_slope ? (slope_val_ok and slope_val_ok[1]) : slope_val_ok
bool slope_ok = use_slope_filter ? slope_persistent : false
bool distance_ok = (not na(atr_distance) and atr_distance >= min_distance) or slope_ok
// 4.2 趋势过滤 (Trend Hysteresis)
bool use_trend_filter = filter_mode != "无过滤"
float trend_buffer = not na(atr_val) ? atr_val * trend_buffer_mult : 0.0
// 核心逻辑修改: 引入缓冲区
bool price_above_center = not na(center) ? close > (center + trend_buffer) : false
bool price_below_center = not na(center) ? close < (center - trend_buffer) : false
bool trend_filter_ok = not use_trend_filter ? true : (not na(center) ? ((trend_up and price_above_center) or (not trend_up and price_below_center)) : trend_up)
// 4.3 HTF 趋势过滤
bool htf_trend_ok = true
if use_htf_filter
    float ema_htf_short = request.security(syminfo.tickerid, htf_period, ta.ema(close, length1))
    float ema_htf_long = request.security(syminfo.tickerid, htf_period, ta.ema(close, length2))
    bool htf_trend_up = ema_htf_short > ema_htf_long
    htf_trend_ok := (trend_up and htf_trend_up) or (not trend_up and not htf_trend_up)
// 4.4 波动与震荡过滤 (严格模式)
bool use_strict = filter_mode == "严格过滤"
float lowest = ta.lowest(length2)
float highest = ta.highest(length2)
bool volatility_ok = true
bool not_chop = true
if use_strict
    float atr_percent = not na(atr_val) and close != 0 ? atr_val / close * 100 : na
    volatility_ok := not na(atr_percent) and atr_percent >= 0.3 and atr_percent <= 2.0
    
    float price_range_percent = not na(highest) and not na(lowest) and close != 0 ? ((highest - lowest) / close) * 100 : na
    not_chop := not na(price_range_percent) and price_range_percent >= 0.5
// [优化] EMA Spread Filter
float spread_threshold = not na(atr_val) ? atr_val * min_ema_spread_mult : 0.0
bool spread_ok = math.abs(ema1 - ema2) > spread_threshold
// 5. 信号生成
var int last_buy_bar = -100
var int last_sell_bar = -100
bool time_ok_buy = (bar_index - last_buy_bar >= min_bars_between_signals)
bool time_ok_sell = (bar_index - last_sell_bar >= min_bars_between_signals)
// 综合信号 (加入 spread_ok)
bool valid_buy = cross_up and trend_filter_ok and htf_trend_ok and distance_ok and volatility_ok and not_chop and time_ok_buy and spread_ok
bool valid_sell = cross_dn and trend_filter_ok and htf_trend_ok and distance_ok and volatility_ok and not_chop and time_ok_sell and spread_ok
// ==========================================
// Reclaim (回调) 逻辑
// ==========================================
var bool waiting_for_reclaim_buy = false
var bool waiting_for_reclaim_sell = false
var float reclaim_ref_price = na 
// 状态机更新
if valid_buy
    waiting_for_reclaim_buy := false
    reclaim_ref_price := na
else if cross_up
    waiting_for_reclaim_buy := true
    waiting_for_reclaim_sell := false
    reclaim_ref_price := high 
if valid_sell
    waiting_for_reclaim_sell := false
    reclaim_ref_price := na
else if cross_dn
    waiting_for_reclaim_sell := true
    waiting_for_reclaim_buy := false
    reclaim_ref_price := low
// Reclaim 触发判断
bool reclaim_buy_sig = false
bool reclaim_sell_sig = false
if use_reclaim and trend_up and not valid_buy
    bool adx_ok = not reclaim_strict_mode or (adx > 20)
    bool breakout = not na(reclaim_ref_price) and close > reclaim_ref_price
    
    if not na(reclaim_ref_price)
        reclaim_ref_price := math.max(reclaim_ref_price, high)
    
    bool rec_time_ok = (bar_index - last_buy_bar >= min_bars_between_signals * 2)
    
    // Reclaim 也加入 spread_ok 检查，确保回调结束时趋势依然有力
    if waiting_for_reclaim_buy and breakout and adx_ok and rec_time_ok and htf_trend_ok and spread_ok
        reclaim_buy_sig := true
        reclaim_ref_price := high 
if use_reclaim and not trend_up and not valid_sell
    bool adx_ok = not reclaim_strict_mode or (adx > 20)
    bool breakout = not na(reclaim_ref_price) and close < reclaim_ref_price
    if not na(reclaim_ref_price)
        reclaim_ref_price := math.min(reclaim_ref_price, low)
        
    bool rec_time_ok = (bar_index - last_sell_bar >= min_bars_between_signals * 2)
    
    if waiting_for_reclaim_sell and breakout and adx_ok and rec_time_ok and htf_trend_ok and spread_ok
        reclaim_sell_sig := true
        reclaim_ref_price := low
// ==========================================
// 绘图与显示 (Plotting)
// ==========================================
float final_offset = (not na(atr_val) ? atr_val : syminfo.mintick * 20) * label_offset_mult
label_size_val = label_size_mode == "小" ? size.small : label_size_mode == "大" ? size.large : size.normal
p1 = plot(ema1, title="EMA短", color=color.new(color.white, 50))
p2 = plot(ema2, title="EMA长", color=color.new(color.yellow, 50))
fill(p1, p2, color = show_trend_fill ? (trend_up ? color.new(col1, 80) : color.new(col2, 80)) : na)
plot(showcl ? center : na, color = showcl ? (center < hl2 ? col1 : col2) : na, title="中心线")
fmtp(v) => str.tostring(math.round(v / syminfo.mintick) * syminfo.mintick)
var label last_drawn_label = na
if valid_buy or reclaim_buy_sig
    txt = valid_buy ? "买入" : "Reclaim"
    if not show_history_labels and not na(last_drawn_label)
        label.delete(last_drawn_label)
    last_drawn_label := label.new(bar_index, low - final_offset, txt + " @ " + fmtp(close), color = col1, textcolor = color.white, style = label.style_label_up, size = label_size_val)
    last_buy_bar := bar_index
if valid_sell or reclaim_sell_sig
    txt = valid_sell ? "卖出" : "Reclaim"
    if not show_history_labels and not na(last_drawn_label)
        label.delete(last_drawn_label)
    last_drawn_label := label.new(bar_index, high + final_offset, txt + " @ " + fmtp(close), color = col2, textcolor = color.white, style = label.style_label_down, size = label_size_val)
    last_sell_bar := bar_index
// ==========================================
// 趋势表 (Trend Table)
// ==========================================
if show_trend_table
    bool up_curr = trend_up
    float c_curr = close
    float atr_curr = atr_val
    string dir_curr = up_curr ? "上涨" : "下跌"
    
    float ema_s_htf = request.security(syminfo.tickerid, htf_period, ta.ema(close, length1))
    float ema_l_htf = request.security(syminfo.tickerid, htf_period, ta.ema(close, length2))
    bool up_htf = ema_s_htf > ema_l_htf
    string dir_htf = up_htf ? "上涨" : "下跌"
    
    float base_price = tp_sl_base == "信号收盘价" ? c_curr : center
    float tp_price = up_curr ? base_price + tp_atr_mult * atr_curr : base_price - tp_atr_mult * atr_curr
    float sl_price = up_curr ? base_price - sl_atr_mult * atr_curr : base_price + sl_atr_mult * atr_curr
    
    var table trend_tbl = table.new(position.top_right, 2, 4, bgcolor = color.new(color.black, 50), border_width = 1)
    
    table.cell(trend_tbl, 0, 0, "趋势监控", text_color=color.white, bgcolor=color.gray)
    table.cell(trend_tbl, 1, 0, "状态", text_color=color.white, bgcolor=color.gray)
    
    table.cell(trend_tbl, 0, 1, "当前趋势", text_color=color.white)
    table.cell(trend_tbl, 1, 1, dir_curr, text_color = up_curr ? col1 : col2)
    
    table.cell(trend_tbl, 0, 2, "HTF (" + htf_period + ")", text_color=color.white)
    table.cell(trend_tbl, 1, 2, dir_htf, text_color = up_htf ? col1 : col2)
    
    table.cell(trend_tbl, 0, 3, "建议 TP/SL", text_color=color.white)
    table.cell(trend_tbl, 1, 3, fmtp(tp_price) + " / " + fmtp(sl_price), text_color=color.white, text_size = size.small)