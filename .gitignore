# AlphaOS .gitignore

# 依赖
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd

# 环境变量（敏感信息）
.env
.env.local
.env.*.local
.env.production
.env.development

# Next.js
.next/
out/
dist/
build/

# 调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试覆盖率
coverage/
*.lcov

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 临时文件
*.log
*.tmp
*.bak
*.backup
*.orig

# Python 虚拟环境
venv/
env/
ENV/

# Docker 卷数据
*.sock

# 数据库备份
*.sql.backup
*.db.backup

# CSV 数据文件（示例数据除外）
*.csv
!example.csv

# 编译产物
*.pyc
*.pyo
*.exe
*.dll
*.so
*.dylib

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# 压缩文件
*.zip
*.tar.gz
*.rar

# 旧文件和备份
*_restore.*
*_old.*
*_backup.*
CHECK_*.sql
SET_*.sql
cleanup_*.sql
query_*.sql
_archive/

# 调试脚本
inspect_*.js
inspect_*.mjs
test_*.py
test_*.js
